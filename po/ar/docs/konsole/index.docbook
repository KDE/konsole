><shortcut
><keycombo action="simul"
>&Ctrl;&Shift;<keycap
>\</keycap
></keycombo
></shortcut
> <guimenu
>عرض</guimenu
><guisubmenu
>شطر العرض</guisubmenu
><guimenuitem
>ساوي حجم جميع العروض</guimenuitem
></menuchoice>
</term>
<listitem
