</para
></listitem>
</varlistentry>

<varlistentry>
<term
><menuchoice
><shortcut
><keycombo action="simul"
>&Ctrl;&Shift;<keycap
>[</keycap
></keycombo
></shortcut
> <guimenu
>عرض</guimenu
><guisubmenu
>شطر العرض</guisubmenu
><guimenuitem
>قلّص العرض</guimenuitem
></menuchoice>
</term>
<listitem
