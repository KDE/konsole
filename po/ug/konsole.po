#: Application.cpp:53
#, kde-format
msgctxt "@info:shell"
msgid "Name of profile to use for new Konsole instance"
msgstr "يېڭى Konsole مىسالى ئۈچۈن ئىشلىتىلىدىغان سەپلىمە ھۆججەتنىڭ ئاتى"

#: Application.cpp:54
#, kde-format
msgctxt "@info:shell"
msgid "json layoutfile to be loaded to use for new Konsole instance"
msgstr "يېڭى Konsole مىسالىغا يۈكلەيدىغان json جايلاشتۇرۇش ھۆججەت"

#: Application.cpp:55
#, kde-format
msgctxt "@info:shell"
msgid "Use the built-in profile instead of the default profile"
msgstr "كۆڭۈلدىكى سەپلىمە ھۆججەتنى ئەمەس، ئىچىدىكى سەپلىمە ھۆججەتنى ئىشلىتىدۇ"

#: Application.cpp:56
#, kde-format
msgctxt "@info:shell"
msgid "Set the initial working directory of the new tab or window to 'dir'"
msgstr ""
"يېڭى بەتكۈچ ياكى كۆزنەكنىڭ دەسلەپكى خىزمەت مۇندەرىجىسىنى «dir» غا تەڭشەيدۇ"

#: Application.cpp:57
#, kde-format
msgctxt "@info:shell"
msgid "Do not close the initial session automatically when it ends."
msgstr "دەسلەپكى جەريانچاق ئاخىرلاشقاندا ئۇنى ئۆزلۈكىدىن ياپمايدۇ."

#: Application.cpp:61
#, kde-format
msgctxt "@info:shell"
msgid ""
"Create a new tab in an existing window rather than creating a new window "
"('Run all Konsole windows in a single process' must be enabled)"
msgstr ""
"يېڭى كۆزنەك قۇرماستىن كۆزنەك ئىچىگە يېڭى بەتكۈچ قۇرىدۇ (چوقۇم «يەككە بىر "
"جەرياندا بارلىق Konsole كۆزنىكىنى ئىجرا قىلىدۇ» قوزغىتىلىدۇ)"

#: Application.cpp:62
#, kde-format
msgctxt "@info:shell"
msgid "Create tabs as specified in given tabs configuration file"
msgstr "بېرىلگەن بەتكۈچ سەپلىمە ھۆججىتىدە بەلگىلەنگەندەك بەتكۈچ قۇرىدۇ"

#: Application.cpp:64
#, kde-format
msgctxt "@info:shell"
msgid ""
"Start Konsole in the background and bring to the front when Ctrl+Shift+F12 "
"(by default) is pressed"
msgstr ""
"Konsole نى ئارقا سۇپىدا باشلايدۇ ۋە Ctrl+Shift+F12 (كۆڭۈلدىكى قىممىتى) "
"كۇنۇپكىسى بېسىلسا ئالدى سۇپىغا ئېلىپ كېلىدۇ"

#: Application.cpp:65
#, kde-format
msgctxt "@info:shell"
msgid "Run in a separate process"
msgstr "ئايرىم جەرياندا ئىجرا قىلىدۇ"

#: Application.cpp:66
#, kde-format
msgctxt "@info:shell"
msgid "Show the menubar, overriding the default setting"
msgstr "تىزىملىك بالداقنى كۆرسىتىدۇ، كۆڭۈلدىكى تەڭشەكنى قاپلايدۇ"

#: Application.cpp:67
#, kde-format
msgctxt "@info:shell"
msgid "Hide the menubar, overriding the default setting"
msgstr "تىزىملىك بالداقنى يوشۇرىدۇ، كۆڭۈلدىكى تەڭشەكنى قاپلايدۇ"

#: Application.cpp:68
#, kde-format
msgctxt "@info:shell"
msgid "Show all the toolbars, overriding the default setting"
msgstr "ھەممە قورال بالداقنى كۆرسىتىدۇ، كۆڭۈلدىكى تەڭشەكنى قاپلايدۇ"

#: Application.cpp:69
#, kde-format
msgctxt "@info:shell"
msgid "Hide all the toolbars, overriding the default setting"
msgstr "ھەممە قورال بالداقنى يوشۇرىدۇ، كۆڭۈلدىكى تەڭشەكنى قاپلايدۇ"

#: Application.cpp:70
#, kde-format
msgctxt "@info:shell"
msgid "Show the tabbar, overriding the default setting"
msgstr "بەتكۈچ بالداقنى كۆرسىتىدۇ، كۆڭۈلدىكى تەڭشەكنى قاپلايدۇ"

#: Application.cpp:71
#, kde-format
msgctxt "@info:shell"
msgid "Hide the tabbar, overriding the default setting"
msgstr "بەتكۈچ بالداقنى يوشۇرىدۇ، كۆڭۈلدىكى تەڭشەكنى قاپلايدۇ"

#: Application.cpp:72
#, kde-format
msgctxt "@info:shell"
msgid "Start Konsole in fullscreen mode"
msgstr "Konsole نى تولۇق ئېكران ھالىتىدە قوزغىتىدۇ"

#: Application.cpp:73
#, kde-format
msgctxt "@info:shell"
msgid "Disable transparent backgrounds, even if the system supports them."
msgstr "سىستېما سۈزۈك تەگلىك ئىقتىدارىنى قوللىغان تەقدىردىمۇ، ئۇنى چەكلەيدۇ."

#: Application.cpp:74
#, kde-format
msgctxt "@info:shell"
msgid "List the available profiles"
msgstr "بار بولغان سەپلىمە ھۆججەت تىزىمى"

#: Application.cpp:75
#, kde-format
msgctxt "@info:shell"
msgid "List all the profile properties names and their type (for use with -p)"
msgstr ""
"بارلىق سەپلىمە ھۆججەت خاسلىقنىڭ ئاتى ۋە ئۇلارنىڭ تىپىنى كۆرسىتىدۇ(-p نىڭ "
"بىلەن بىرگە ئىشلىتىش ئۈچۈن)"

#: Application.cpp:76
#, kde-format
msgctxt "@info:shell"
msgid "Change the value of a profile property."
msgstr "سەپلىمە ھۆججەت خاسلىقىنىڭ قىممىتىنى ئۆزگەرتىدۇ."

#: Application.cpp:78
#, kde-format
msgctxt "@info:shell"
msgid ""
"Command to execute. This option will catch all following arguments, so use "
"it as the last option."
msgstr ""
"ئىجرا قىلىدىغان بۇيرۇق. بۇ تاللانما تۆۋەندىكى بارلىق ئەركىن ئۆزگەرگۈچىگە "
"ئېرىشىدۇ، شۇڭا ئەڭ ئاخىرقى تاللانما سۈپىتىدە ئىشلىتىلىدۇ."

#: Application.cpp:81
#, kde-format
msgctxt "@info:shell"
msgid ""
"Force re-using the existing instance even if it breaks functionality, e. g. "
"--new-tab. Mostly for debugging."
msgstr ""
"بەزى ئىقتىدارنى بۇزغان تەقدىردىمۇ مەۋجۇت مىسالنى مەجبۇرىي قايتا ئىشلىتىدۇ. "
"مەسىلەن، «--new-tab». ئاساسلىقى سازلاشقا ئىشلىتىلىدۇ."

#: Application.cpp:88
#, kde-format
msgctxt "@info:shell"
msgid "Arguments passed to command"
msgstr "بۇيرۇققا بېرىلىدىغان ئەركىن ئۆزگەرگۈچى"

